# App
APP_NAME=market-data-service
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false

# Database (must include TimescaleDB)
DATABASE_URL=postgresql+psycopg://quantos:quantos_local@localhost:5432/quantos

# Redis
REDIS_URL=redis://localhost:6379/1

# CORS
CORS_ORIGINS=http://localhost:3000

# Data provider API keys (gate behind env flags — never commit real values)
POLYGON_API_KEY=
ALPHAVANTAGE_API_KEY=
FINNHUB_API_KEY=
NEWSAPI_KEY=
ENABLE_POLYGON=false
