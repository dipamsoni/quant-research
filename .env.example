# Copy to .env for local dev. Never commit .env.
# Production secrets live in your hosting provider's secret manager.

# ─── Postgres ──────────────────────────────────────────────
POSTGRES_DB=quantos
POSTGRES_USER=quantos
POSTGRES_PASSWORD=quantos_local
DATABASE_URL=postgresql+asyncpg://quantos:quantos_local@postgres:5432/quantos
DATABASE_URL_SYNC=postgresql+psycopg2://quantos:quantos_local@postgres:5432/quantos

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Auth ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_64_hex_chars
JWT_REFRESH_SECRET=change_me_different_64_hex_chars
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# ─── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Frontend ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Phase 2: Market data providers ────────────────────────
# Free tier; sign up at the provider sites
ALPHAVANTAGE_API_KEY=
POLYGON_API_KEY=
FINNHUB_API_KEY=

# ─── Phase 4: ML / MLflow ──────────────────────────────────
MLFLOW_TRACKING_URI=file:./data/mlflow

# ─── Phase 6: AI / LLM ─────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# ─── Phase 11+: Observability ──────────────────────────────
SENTRY_DSN=
LOGTAIL_TOKEN=

# ─── Phase 11+: Streaming ──────────────────────────────────
# KAFKA_BOOTSTRAP_SERVERS=
# KAFKA_SCHEMA_REGISTRY_URL=

# ─── Internal service auth (Phase 4+) ──────────────────────
INTERNAL_SERVICE_TOKEN=change_me_internal_token

# ─── Environment marker ────────────────────────────────────
ENVIRONMENT=local
